# Optional — only needed for cloud NVIDIA models
NVIDIA_API_KEY=your_nvidia_api_key_here

# LLM provider: auto | nvidia | ollama | local
LLM_PROVIDER=auto

# Ollama settings (only used when provider=ollama)
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:0.5b

# Local in-process GGUF settings (only used when provider=local)
LOCAL_MODEL_REPO=Qwen/Qwen2.5-Coder-0.5B-Instruct-GGUF
LOCAL_MODEL_FILE=qwen2.5-coder-0.5b-instruct-q4_k_m.gguf
LOCAL_MODEL_CONTEXT_SIZE=4096
LOCAL_MODEL_N_THREADS=0

# Self-improvement loop
# Require manual approval before candidate mutations are applied (recommended)
REQUIRE_HUMAN_APPROVAL=true
# Repetitions per benchmark when scoring a harness version (averaged)
BENCHMARK_RUNS=3
# Reuse previously recorded benchmark scores for a version
BENCHMARK_CACHE=true
# Cap on auto-generated benchmarks
MAX_AUTO_BENCHMARKS=50

# Optional extras
SEARCH_API_KEY=optional_tavily_or_brave_key
PORTAL_DEV_TOKEN=dev_token_for_portal_auth
